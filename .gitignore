# Build artifacts
pharos
pharos.exe

# Tailwind CSS standalone binary
.bin/

# Tailwind CSS source (rebuilt via `make css`)
# internal/web/app.css is committed so //go:embed resolves in CI.
web/app.css

# Installed skills from 'pharos skills install'
.claude/
.codex/
.opencode/
.pi/
.agents/skills/
skills-lock.json

# Playwright test artifacts
.playwright-mcp/
design/
test-results/

# Debugging screenshots
glossary-page.png
glossary-snapshot
glossary-updated.png
mermaid-toolbar-visible.png

# Architecture notes (ADRs, etc.)
.docs/

# Handoff documents (session-to-session transfer, not repo artifacts)
.handoffs/

# lific issue tracker local DB
lific.db
lific.db-shm
lific.db-wal

# Dev hot-reload (`pharos dev`)
tmp/

# GoReleaser build output
dist/

# Windows PE resource metadata (generated by scripts/gen-winres.sh at build time)
cmd/pharos/*.syso
